{
  "name": "daemon-dungeon",
  "version": "0.1.0",
  "description": "Daemon Dungeon - Roguelike 3D isometric game",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "analyze:assets": "node scripts/analyze-assets.mjs",
    "optimize:models": "node scripts/optimize-models.mjs",
    "optimize:models:write": "node scripts/optimize-models.mjs --write",
    "optimize:models:aggressive": "node scripts/optimize-models.mjs --aggressive",
    "optimize:models:aggressive:write": "node scripts/optimize-models.mjs --aggressive --write",
    "optimize:models:meshopt": "node scripts/optimize-models.mjs --meshopt",
    "optimize:models:meshopt:write": "node scripts/optimize-models.mjs --meshopt --write",
    "restore:models": "node scripts/restore-model-backups.mjs",
    "build:voice-lab": "esbuild src/tools/daemonVoiceLab/main.ts --bundle --platform=browser --format=esm --outfile=daemon-voice-lab.bundle.js",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:ci": "eslint src --ext .ts,.tsx --max-warnings=0",
    "ci:local": "npm run lint:ci && npm run build",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\""
  },
  "dependencies": {
    "@babylonjs/core": "^6.0.0",
    "@babylonjs/gui": "^6.0.0",
    "@babylonjs/havok": "^1.3.12",
    "@babylonjs/loaders": "^6.0.0",
    "mespeak": "^2.0.2"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.1.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
